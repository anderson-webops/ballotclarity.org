{
	"name": "front-end",
	"version": "1.0.0",
	"description": "Nuxt front-end for the Ballot Clarity civic-information MVP",
	"author": "Jacob Anderson",
	"keywords": [],
	"license": "ISC",
	"type": "module",
	"private": true,
	"main": ".output/server/index.mjs",
	"scripts": {
		"prepare": "nuxt prepare",
		"build": "nuxt build",
		"dev": "nuxt dev --port 3333 --open",
		"start": "npm run serve",
		"serve": "nuxt dev --port 3333 --open --host",
		"preview": "nuxt preview --port 3333 --host",
		"dev:pwa": "VITE_PLUGIN_PWA=true nuxt dev --port 3333 --open",
		"typecheck": "nuxt typecheck",
		"lint": "nuxt prepare && eslint \"src/**/*.{js,ts,vue}\" \"test/**/*.ts\" \"*.config.{js,ts,mjs}\"",
		"lint-fix": "nuxt prepare && eslint \"src/**/*.{js,ts,vue}\" \"test/**/*.ts\" \"*.config.{js,ts,mjs}\" --fix",
		"test:unit": "node --test --import tsx test/*.test.ts"
	},
	"dependencies": {
		"@iconify-json/carbon": "^1.2.19",
		"@iconify-json/twemoji": "^1.2.5",
		"@nuxt/devtools": "^4.0.0-alpha.4",
		"@nuxt/eslint": "^1.15.2",
		"@nuxtjs/color-mode": "^4.0.0",
		"@pinia/nuxt": "^0.11.3",
		"@unocss/nuxt": "^66.6.7",
		"@vite-pwa/nuxt": "^1.1.1",
		"@vueuse/core": "^14.2.1",
		"@vueuse/nuxt": "^14.2.1",
		"nuxt": "^4.4.2",
		"pinia": "^3.0.4",
		"unocss": "^66.6.7",
		"vue": "^3.5.30"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"eslint-plugin-format": "^2.0.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vue-tsc": "^3.2.6"
	}
}
