{
	"name": "back-end",
	"version": "1.0.0",
	"private": true,
	"description": "Express API for the Ballot Clarity civic-information MVP",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"server": "tsx watch -r dotenv/config src/server.ts",
		"server:once": "tsx -r dotenv/config src/server.ts",
		"start": "node dist/server.js",
		"build": "tsc -p tsconfig.json",
		"watch": "tsc -w",
		"dev": "tsx watch -r dotenv/config src/server.ts",
		"lint": "eslint \"src/**/*.{js,ts}\" \"test/**/*.ts\"",
		"lint-fix": "eslint \"src/**/*.{js,ts}\" \"test/**/*.ts\" --fix",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"test": "node --test --import tsx test/*.test.ts"
	},
	"dependencies": {
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^5.1.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.3",
		"@types/node": "^25.5.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
