{
	"name": "back-end",
	"version": "1.0.0",
	"private": true,
	"description": "Express API for the Ballot Clarity civic-information MVP",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"server": "DOTENV_CONFIG_PATH=../.env tsx watch -r dotenv/config src/server.ts",
		"server:once": "DOTENV_CONFIG_PATH=../.env tsx -r dotenv/config src/server.ts",
		"bootstrap-admin": "npm run bootstrap-admin:dist --",
		"bootstrap-admin:src": "tsx src/bootstrap-admin.ts",
		"bootstrap-admin:dist": "node dist/bootstrap-admin.js",
		"bootstrap-admin:local": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/bootstrap-admin.js",
		"export-seed-coverage": "node dist/export-seed-coverage.js",
		"export-seed-coverage:src": "tsx src/export-seed-coverage.ts",
		"export-seed-coverage:local": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/export-seed-coverage.js",
		"export:fulton-reviewed-coverage": "node dist/export-fulton-reviewed-coverage.js",
		"export:fulton-reviewed-coverage:src": "tsx src/export-fulton-reviewed-coverage.ts",
		"export:fulton-reviewed-coverage:local": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/export-fulton-reviewed-coverage.js",
		"ingest:coverage": "node dist/import-live-coverage.js",
		"ingest:coverage:src": "tsx src/import-live-coverage.ts",
		"ingest:coverage:local": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/import-live-coverage.js",
		"manage:coverage": "node dist/manage-live-coverage.js",
		"manage:coverage:src": "tsx src/manage-live-coverage.ts",
		"manage:coverage:local": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/manage-live-coverage.js",
		"sync:launch-directory": "npm run sync:launch-directory:dist",
		"sync:launch-directory:src": "tsx src/sync-launch-directory.ts",
		"sync:launch-directory:dist": "node dist/sync-launch-directory.js",
		"sync:launch-directory:local": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/sync-launch-directory.js",
		"providers:test": "npm run providers:test:dist",
		"providers:test:src": "tsx src/test-providers.ts",
		"providers:test:dist": "node dist/test-providers.js",
		"providers:test:local": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/test-providers.js",
		"start": "node dist/server.js",
		"start:local": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/server.js",
		"build": "tsc -p tsconfig.json && node ./scripts/copy-runtime-assets.mjs",
		"watch": "tsc -w",
		"dev": "DOTENV_CONFIG_PATH=../.env tsx watch -r dotenv/config src/server.ts",
		"lint": "eslint \"src/**/*.{js,ts}\" \"test/**/*.ts\"",
		"lint-fix": "eslint \"src/**/*.{js,ts}\" \"test/**/*.ts\" --fix",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"test": "node --test --import tsx test/*.test.ts"
	},
	"dependencies": {
		"cors": "^2.8.5",
		"dotenv": "^17.4.2",
		"express": "^5.1.0",
		"pg": "^8.16.3"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.3",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.15.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
