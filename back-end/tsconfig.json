{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"incremental": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"typeRoots": ["./node_modules/@types"],
		"sourceMap": true,
		"outDir": "./dist",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
