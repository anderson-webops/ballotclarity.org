{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"types": ["node"],
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"noEmit": true
	},
	"include": ["src/**/*", "test/**/*"],
	"exclude": ["node_modules", "dist"]
}
