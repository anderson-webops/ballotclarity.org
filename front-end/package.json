{
	"name": "front-end",
	"version": "1.0.0",
	"description": "Nuxt front-end for the Ballot Clarity civic-information service",
	"author": "Jacob Anderson",
	"keywords": [],
	"license": "MIT",
	"type": "module",
	"private": true,
	"main": ".output/server/index.mjs",
	"scripts": {
		"prepare": "nuxt prepare",
		"build": "nuxt build",
		"dev": "nuxt dev --port 3333 --open",
		"start": "npm run serve",
		"serve": "nuxt dev --port 3333 --open --host",
		"preview": "nuxt preview --port 3333 --host",
		"typecheck": "nuxt typecheck",
		"lint": "nuxt prepare && eslint \"src/**/*.{js,ts,vue}\" \"server/**/*.ts\" \"test/**/*.ts\" \"*.config.{js,ts,mjs}\"",
		"lint-fix": "nuxt prepare && eslint \"src/**/*.{js,ts,vue}\" \"server/**/*.ts\" \"test/**/*.ts\" \"*.config.{js,ts,mjs}\" --fix",
		"test:unit": "node --test --import tsx test/*.test.ts",
		"verify:analytics": "node scripts/verify-analytics-output.mjs"
	},
	"dependencies": {
		"@iconify-json/carbon": "^1.2.23",
		"@iconify-json/twemoji": "^1.2.5",
		"@nuxt/eslint": "^1.16.0",
		"@nuxtjs/color-mode": "^4.0.1",
		"@pinia/nuxt": "^0.11.3",
		"@unocss/nuxt": "^66.7.2",
		"@vueuse/core": "^14.3.0",
		"@vueuse/nuxt": "^14.3.0",
		"nuxt": "^4.4.8",
		"pinia": "^3.0.4",
		"unocss": "^66.7.2",
		"vue": "^3.5.38",
		"vue-router": "^5.1.0"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"eslint-plugin-format": "^2.0.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vue-tsc": "^3.3.5"
	}
}
