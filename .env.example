# Public runtime values
NUXT_PUBLIC_SITE_URL=https://ballotclarity.example.org
NUXT_PUBLIC_API_BASE=http://127.0.0.1:3001/api

# Server-only admin bridge values
# ADMIN_API_BASE must be a private server-to-server origin the Nuxt server can reach.
# Browser requests to /api/admin/* should terminate at the Nuxt server, not at the Express API directly.
ADMIN_API_BASE=http://127.0.0.1:3001/api
ADMIN_API_KEY=replace-with-a-long-random-internal-key
ADMIN_SESSION_SECRET=replace-with-a-long-random-session-secret
ADMIN_STORE_DRIVER=sqlite
ADMIN_DB_PATH=./back-end/data/ballot-clarity.sqlite
# ADMIN_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ballot_clarity

# Public source-asset delivery
# Set SOURCE_ASSET_BASE_URL when mirrored source files should be served from object storage or a CDN.
# Example: https://assets.ballotclarity.org/source-files
# SOURCE_ASSET_BASE_URL=

# One-time bootstrap values for the first persisted admin account
ADMIN_BOOTSTRAP_USERNAME=founder-admin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-long-random-password
ADMIN_BOOTSTRAP_DISPLAY_NAME=Ballot Clarity Admin
ADMIN_BOOTSTRAP_ROLE=admin

# Imported coverage snapshots
# Use npm run ingest:coverage to write this file from a vetted JSON source.
LIVE_COVERAGE_FILE=./back-end/data/live-coverage.json
LIVE_COVERAGE_REQUIRED=false
# LIVE_COVERAGE_SOURCE_FILE=./ops/live-coverage.json
# LIVE_COVERAGE_SOURCE_URL=https://internal.ballotclarity.org/coverage/latest.json

# Back-end runtime
PORT=3001
TRUST_PROXY=false
LOG_LEVEL=info
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MS=1800000
