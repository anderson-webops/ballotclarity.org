# Public runtime values
NUXT_PUBLIC_SITE_URL=https://ballotclarity.example.org
NUXT_PUBLIC_API_BASE=http://127.0.0.1:3001/api

# Local infrastructure defaults
POSTGRES_DB=ballot_clarity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
MINIO_BUCKET=source-files
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Server-only admin bridge values
# ADMIN_API_BASE must be a private server-to-server origin the Nuxt server can reach.
# Browser requests to /api/admin/* should terminate at the Nuxt server, not at the Express API directly.
ADMIN_API_BASE=http://127.0.0.1:3001/api
ADMIN_API_KEY=replace-with-a-long-random-internal-key
ADMIN_SESSION_SECRET=replace-with-a-long-random-session-secret
ADMIN_STORE_DRIVER=postgres
ADMIN_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:${POSTGRES_PORT}/${POSTGRES_DB}
# ADMIN_DB_PATH=./back-end/data/ballot-clarity.sqlite

# Public source-asset delivery
# Set SOURCE_ASSET_BASE_URL when mirrored source files should be served from object storage or a CDN.
# Example: https://assets.ballotclarity.org/source-files
# Local MinIO example: http://127.0.0.1:${MINIO_PORT}/${MINIO_BUCKET}
# SOURCE_ASSET_BASE_URL=

# One-time bootstrap values for the first persisted admin account
ADMIN_BOOTSTRAP_USERNAME=founder-admin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-long-random-password
ADMIN_BOOTSTRAP_DISPLAY_NAME=Ballot Clarity Admin
ADMIN_BOOTSTRAP_ROLE=admin

# Civic and AI provider keys
# Keep all of these server-side only. Do not expose paid or quota-limited keys to the browser.
# Census geocoding does not require an API key.
# DATA_API_KEY is the shared api.data.gov credential and can be reused for Congress.gov and OpenFEC.
# Set GOOGLE_CIVIC_FORCE_IPV4=true when the server egresses over IPv6 by default but the Google Civic key is restricted to the server's IPv4.
# Census geocoder defaults can stay at their current values unless you need a specific benchmark or vintage for reproducibility.
# GOOGLE_CIVIC_API_KEY=
# GOOGLE_CIVIC_FORCE_IPV4=false
# DATA_API_KEY=
# CONGRESS_API_KEY=
# OPENFEC_API_KEY=
# OPENSTATES_API_KEY=
# LDA_API_KEY=
# OPENAI_API_KEY=
# CENSUS_GEOCODER_BENCHMARK=Public_AR_Current
# CENSUS_GEOCODER_VINTAGE=Current_Current

# Launch-directory ingestion snapshot
# Use npm run launch-directory:sync to write this file from provider data.
LAUNCH_DIRECTORY_FILE=./data/launch-directory.local.json
# Default launch probe coordinates point at downtown Atlanta/Fulton for Open States geo matching.
# LAUNCH_PROFILE_LATITUDE=33.7490
# LAUNCH_PROFILE_LONGITUDE=-84.3880

# Imported coverage snapshots
# Use npm run ingest:coverage to write this file from a vetted JSON source.
LIVE_COVERAGE_FILE=./data/live-coverage.local.json
LIVE_COVERAGE_REQUIRED=false
# LIVE_COVERAGE_SOURCE_FILE=./ops/live-coverage.json
# LIVE_COVERAGE_SOURCE_URL=https://internal.ballotclarity.org/coverage/latest.json

# Back-end runtime
PORT=3001
TRUST_PROXY=false
LOG_LEVEL=info
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MS=1800000
