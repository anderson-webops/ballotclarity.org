{
	"name": "back-end",
	"version": "1.0.0",
	"private": true,
	"description": "Express API for the Ballot Clarity civic-information MVP",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"server": "DOTENV_CONFIG_PATH=../.env tsx watch -r dotenv/config src/server.ts",
		"server:once": "DOTENV_CONFIG_PATH=../.env tsx -r dotenv/config src/server.ts",
		"bootstrap-admin": "DOTENV_CONFIG_PATH=../.env tsx -r dotenv/config src/bootstrap-admin.ts",
		"export-seed-coverage": "DOTENV_CONFIG_PATH=../.env tsx -r dotenv/config src/export-seed-coverage.ts",
		"ingest:coverage": "DOTENV_CONFIG_PATH=../.env tsx -r dotenv/config src/import-live-coverage.ts",
		"providers:test": "DOTENV_CONFIG_PATH=../.env tsx -r dotenv/config src/test-providers.ts",
		"start": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config dist/server.js",
		"build": "tsc -p tsconfig.json && node ./scripts/copy-runtime-assets.mjs",
		"watch": "tsc -w",
		"dev": "DOTENV_CONFIG_PATH=../.env tsx watch -r dotenv/config src/server.ts",
		"lint": "eslint \"src/**/*.{js,ts}\" \"test/**/*.ts\"",
		"lint-fix": "eslint \"src/**/*.{js,ts}\" \"test/**/*.ts\" --fix",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"test": "node --test --import tsx test/*.test.ts"
	},
	"dependencies": {
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^5.1.0",
		"pg": "^8.16.3"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.3",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.15.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
