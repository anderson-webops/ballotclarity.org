{
	"name": "ballot-clarity-monorepo",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"packageManager": "npm@11.7.0",
	"description": "Monorepo for the Ballot Clarity civic-information MVP",
	"author": "Jacob Anderson",
	"license": "ISC",
	"keywords": [],
	"workspaces": [
		"front-end",
		"back-end"
	],
	"scripts": {
		"postinstall": "npm run -w front-end prepare",
		"audit": "node scripts/security-audit.mjs",
		"audit:raw": "npm audit --workspaces",
		"audit-fix": "npm audit fix --workspaces",
		"build": "npm run -w front-end build && npm run -w back-end build",
		"db:down": "docker compose down",
		"db:up": "docker compose up -d postgres",
		"env:local": "node ./scripts/create-local-env.mjs",
		"dev": "npm run -w front-end dev",
		"dev:local": "node ./scripts/run-local-command.mjs --provider-local -- npm run -w front-end dev",
		"server": "npm run -w back-end server",
		"server:once": "npm run -w back-end server:once",
		"server:local": "node ./scripts/run-local-command.mjs --provider-local -- npm run -w back-end server:once",
		"server:local:watch": "node ./scripts/run-local-command.mjs --provider-local -- npm run -w back-end server",
		"bootstrap-admin": "npm run -w back-end bootstrap-admin --",
		"bootstrap-admin:local": "node ./scripts/run-local-command.mjs --provider-local -- npm run -w back-end bootstrap-admin:src --",
		"coverage:seed-local": "npm run -w back-end export-seed-coverage",
		"coverage:seed-local:local": "node ./scripts/run-local-command.mjs --provider-local -- npm run -w back-end export-seed-coverage:src",
		"coverage:fulton-reviewed": "npm run -w back-end export:fulton-reviewed-coverage",
		"coverage:fulton-reviewed:local": "node ./scripts/run-local-command.mjs --provider-local -- npm run -w back-end export:fulton-reviewed-coverage:src",
		"launch-directory:sync": "npm run -w back-end sync:launch-directory",
		"launch-directory:sync:local": "node ./scripts/run-local-command.mjs --provider-local -- npm run -w back-end sync:launch-directory:src",
		"launch-directory:sync:src": "npm run -w back-end sync:launch-directory:src",
		"providers:test": "npm run -w back-end providers:test",
		"providers:test:local": "node ./scripts/run-local-command.mjs --provider-local -- npm run -w back-end providers:test:src",
		"providers:test:src": "npm run -w back-end providers:test:src",
		"local:setup": "node ./scripts/setup-local-provider.mjs",
		"verify:local": "node ./scripts/verify-local-runtime.mjs",
		"verify:production": "node ./scripts/production-config-check.mjs",
		"verify:analytics": "npm run -w front-end verify:analytics",
		"serve": "npm run -w front-end serve",
		"preview": "npm run -w front-end preview",
		"stack:down": "docker compose down",
		"stack:reset": "docker compose down -v",
		"stack:up": "docker compose up -d postgres minio minio-init",
		"storage:up": "docker compose up -d minio minio-init",
		"test": "npm run test:unit",
		"test:repo": "node --test --import tsx test/*.unit.test.ts",
		"test:unit": "npm run test:repo && npm run -w front-end test:unit && npm run -w back-end test",
		"test:e2e": "npm run build && node --test --import tsx test/e2e-smoke.test.ts",
		"lint-server": "npm run -w back-end lint-fix && npm run -w back-end server",
		"lint-serve": "npm run -w front-end lint-fix && npm run -w front-end serve",
		"lint": "npm run -w front-end lint && npm run -w back-end lint",
		"lint-fix": "npm run -w front-end lint-fix && npm run -w back-end lint-fix",
		"typecheck": "npm run -w front-end typecheck && npm run -w back-end typecheck",
		"clean": "rm -rf node_modules package-lock.json front-end/.nuxt front-end/.output front-end/node_modules front-end/package-lock.json back-end/dist back-end/node_modules back-end/package-lock.json",
		"a11y": "node scripts/a11y-smoke.mjs"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^8.3.0",
		"@typescript-eslint/eslint-plugin": "^8.61.0",
		"@typescript-eslint/parser": "^8.61.0",
		"@unocss/eslint-plugin": "^66.7.2",
		"axe-core": "^4.12.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-vue": "^10.9.2",
		"globals": "^17.6.0",
		"prettier": "^3.8.4",
		"puppeteer": "^24.43.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0"
	},
	"overrides": {
		"nitropack": "2.13.4",
		"simple-git": "3.36.0"
	}
}
